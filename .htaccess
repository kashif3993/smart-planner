RewriteEngine On

# IMPORTANT: If deploying to a live server root domain (e.g., eventpro.com), 
# change the RewriteBase to / and update the DOCUMENT_ROOT conditions accordingly.
RewriteBase /smart-planner/

# If the request is for a valid directory or file, serve it directly
RewriteCond %{REQUEST_FILENAME} -d [OR]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route /dashboard to index.php
RewriteRule ^dashboard/?$ index.php [L,QSA]

# Route pages to pages directory
# Allows domain.com/smart-planner/timeline instead of timeline.php
RewriteCond %{DOCUMENT_ROOT}/smart-planner/pages/$1.php -f
RewriteRule ^([a-zA-Z0-9_-]+)/?$ pages/$1.php [L,QSA]

# Hide .php extensions for other pages in the root
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]
